# 권순기.kr 환경변수
# 로컬: .env.local 에 복사해서 채워 넣고 vite dev 재시작
# 운영: Cloudflare Pages → Settings → Environment variables 에 같은 키 등록

# Supabase (필수: /fair, /report, /fair/admin 동작)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Cloudflare Turnstile site key (선택, 봇 방지)
# Cloudflare → Turnstile → Add site (mode: Managed, domain: 권순기.kr 또는 punycode, localhost)
VITE_TURNSTILE_SITE_KEY=<turnstile-site-key>

# Google Analytics 4 (선택, 미설정 시 추적 X)
VITE_GA_ID=<measurement-id>
